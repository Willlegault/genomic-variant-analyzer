# Copy to .env and fill in. .env is gitignored.

# Supabase — used for analysis history persistence.
# Create a project at https://supabase.com, then read these from
# Project Settings → API.
SUPABASE_URL=
SUPABASE_KEY=

# Optional: contact email NCBI asks API users to provide so they can
# reach you if your traffic causes problems. Anything reachable is fine.
NCBI_EMAIL=

# Frontend origin allowed by CORS. In dev this is the Next.js dev server.
# In prod set to the deployed frontend URL.
FRONTEND_ORIGIN=http://localhost:3000
